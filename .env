# =========================================================================
# FaceSnap Core Database & API Configuration
# =========================================================================

# 1. pgvector Database Connection URL (uses Supabase transaction pooler on port 6543)
# Format: postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres
DATABASE_URL=""

# 2. JWT Authentication Settings
# - JWT_SECRET: A strong secure hex string (generate using 'openssl rand -hex 32')
# - JWT_ALGORITHM: The cryptographic algorithm used for signing (HS256 by default)
JWT_SECRET=""
JWT_ALGORITHM=""
ACCESS_TOKEN_EXPIRE_MINUTES=""

# 3. Supabase Client API Config
# - SUPABASE_URL: The unique URL of your Supabase project (https://[PROJECT_REF].supabase.co)
# - SUPABASE_KEY: The service role API key sourced from project Settings -> API
# - SUPABASE_BUCKET: The public Supabase storage bucket used for uploads ('facesnap-memories')
SUPABASE_URL=""
SUPABASE_KEY=""
SUPABASE_BUCKET=""
