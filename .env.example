# =========================================================================
# FaceSnap AI Backend Configuration Template
# Rename this file to .env and fill in your Supabase credentials.
# WARNING: Do not commit the actual .env file to Git!
# =========================================================================

# Database connection URL (pgvector PostgreSQL)
# For Supabase, use the transaction pooler (port 5432) or session pooler (port 6543)
# Format: postgresql+asyncpg://[USER]:[PASSWORD]@[HOST]:[PORT]/[DB_NAME]
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR_SUPABASE_DB_PASSWORD]@db.bcahxnvuodsslmeqdnin.supabase.co:5432/postgres

# Supabase API Settings
# Sourced from your Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://bcahxnvuodsslmeqdnin.supabase.co
SUPABASE_KEY=your_supabase_service_role_secret_key_here

# JWT Authentication Secret Key
# Generate a strong secure hex string using: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
